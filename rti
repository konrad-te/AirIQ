class Solution(object):
    def romanToInt(self, s):
        """
        :type s: str
        :rtype: int
        """
        result = 0
        for letter in s:
            if letter == "I":
                result += 1
            elif letter == "V":
                result += 5
        return result
        
solution = Solution()
result = solution.romanToInt("III")
print(result)

