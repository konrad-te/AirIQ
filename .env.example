# AirIQ environment example
# Copy the backend section into backend/.env
# Copy the frontend section into frontend2.0/.env

# ----------------------------
# Backend (.env in /backend)
# ----------------------------

# Required for local database access.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=airiq
DB_USER=postgres
DB_PASSWORD=postgres

# Use "disable" for local Postgres, or "require" for managed databases with SSL.
DB_SSLMODE=disable

# Strongly recommended for encrypted credentials used by integrations and Discord webhook storage.
FIELD_ENCRYPTION_KEY=replace-with-a-generated-fernet-key

# App behavior
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MAX_ACTIVE_SESSIONS_PER_USER=20
SQLALCHEMY_ECHO=0

# Optional provider and API settings
AIRLY_API_KEY=
OPENAQ_API_KEY=
NOMINATIM_USER_AGENT=AirIQ-Open-Source-Dev/1.0 (you@example.com)
NOMINATIM_EMAIL=you@example.com
GOOGLE_API_KEY=
POSTMARK_API_TOKEN=
EMAIL_FROM=noreply@example.com

# Optional Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/strava/callback
STRAVA_STATE_SECRET=
STRAVA_SCOPES=activity:read_all

# Optional Qingping overrides
QINGPING_SCOPE=device_full_access
QINGPING_TIMEOUT_SECONDS=20
QINGPING_SYNC_INTERVAL_MINUTES=5

# Optional system-level Discord monitor webhook
DISCORD_WEBHOOK_URL=

# ----------------------------
# Frontend (.env in /frontend2.0)
# ----------------------------

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_MAPBOX_TOKEN=
VITE_STUDIO_STYLE_URL=
