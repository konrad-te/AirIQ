# Database (AWS RDS)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=airiq
DB_USER=postgres
DB_PASSWORD=your-password
DB_SSLMODE=require

# API Keys
AIRLY_API=your-airly-api-key
OPEN_AQ=your-openaq-api-key
IQAIR_API=your-iqair-api-key
GOOGLE_API_KEY=your-google-api-key

# Nominatim (use a real contact email)
NOMINATIM_USER_AGENT=AirIQ/1.0 (YourName; contact: you@example.com)
NOMINATIM_EMAIL=you@example.com

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-domain.com

# Optional tuning
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
SQLALCHEMY_ECHO=0
CACHE_RAW=0
